<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:sdparm_GUI.ViewModels"
        mc:Ignorable="d" d:DesignWidth="950" d:DesignHeight="700"
        Width="950" Height="700"
        WindowStartupLocation="CenterScreen"
        x:Class="sdparm_GUI.MainWindow"
        Title="sdparm GUI">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,*,Auto,2*" Margin="10">

        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto,*" Margin="0,0,0,8">
            <TextBlock Grid.Column="0" Text="sdparm path:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox Grid.Column="1" Text="{Binding ExecutablePath}" Margin="0,0,12,0"/>
            <TextBlock Grid.Column="2" Text="Device:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox Grid.Column="3" Text="{Binding DevicePath}" Watermark="/dev/sda or PD0"/>
        </Grid>

        <Border Grid.Row="1" Background="#1e1e1e" Padding="8" Margin="0,0,0,8" CornerRadius="4">
            <TextBlock Text="{Binding CommandPreview}" Foreground="#dcdcdc" FontFamily="Consolas,Menlo,monospace"/>
        </Border>

        <Border Grid.Row="2" BorderBrush="Gray" BorderThickness="1" Margin="0,0,0,8">
            <ScrollViewer>
                <ItemsControl Items="{Binding Options}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="240,*,160" Margin="4">
                                <CheckBox Grid.Column="0" Content="{Binding DisplayName}" IsChecked="{Binding IsSelected}" ToolTip.Tip="{Binding Description}"/>
                                <TextBlock Grid.Column="1" Text="{Binding Description}" TextWrapping="Wrap" Opacity="0.7" Margin="8,0" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="2" Text="{Binding Value}" IsVisible="{Binding RequiresValue}" Watermark="value"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <Button Content="Run" Command="{Binding RunCommand}"/>
            <Button Content="Cancel" Command="{Binding CancelCommand}"/>
            <Button Content="Clear Output" Command="{Binding ClearOutputCommand}"/>
        </StackPanel>

        <Border Grid.Row="4" Background="Black" CornerRadius="4">
            <ScrollViewer>
                <TextBox Text="{Binding OutputText}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="NoWrap"
                         FontFamily="Consolas,Menlo,monospace"
                         Foreground="LightGreen"
                         Background="Transparent"
                         BorderThickness="0"/>
            </ScrollViewer>
        </Border>

    </Grid>
</Window>
